# ブラウザからアクセスする開発用ポートです。
APP_PORT=8080
# JavaScript開発サーバーへアクセスするポートです。
FRONTEND_PORT=5173
# FuelPHPの実行環境です。本番ではproductionへ変更します。
FUEL_ENV=development
# 実際の秘密値はGit管理外の.envだけに設定します。
DB_HOST=database
DB_PORT=3306
DB_NAME=change_me_database
DB_USER=change_me_user
DB_PASSWORD=change_me_password
DB_ROOT_PASSWORD=change_me_root_password
# ブラウザからAPIを呼ぶ際の同一オリジンURLです。
API_BASE_URL=/api
